# Core OTP delivery
OTP_PROVIDER=console
OTP_MESSAGE_TEMPLATE=MetroBus OTP is {code}. Valid for 5 minutes. Do not share it.

# Local MetroBus web/mobile LAN testing
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_URL=http://127.0.0.1:5173

# Sparrow SMS
SPARROW_SMS_URL=https://api.sparrowsms.com/v2/sms/
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=

# Optional reminder for deployment
# Sparrow may require your server IP to be allowlisted in their dashboard.
SPARROW_IP_WHITELISTED=no

# Khalti ePayment
KHALTI_API_URL=https://dev.khalti.com/api/v2
KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=

# Email SMTP (Gmail App Password recommended)
EMAIL_HOST_USER=aryanadhikari2062@gmail.com
EMAIL_HOST_PASSWORD=
