# Core OTP delivery
OTP_PROVIDER=console
OTP_MESSAGE_TEMPLATE=MetroBus OTP is {code}. Valid for 5 minutes. Do not share it.

# Sparrow SMS
SPARROW_SMS_URL=https://api.sparrowsms.com/v2/sms/
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=

# Optional reminder for deployment
# Sparrow may require your server IP to be allowlisted in their dashboard.
SPARROW_IP_WHITELISTED=no
